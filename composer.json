{
    "name": "apavliukov/laravel-authorization",
    "description": "Reusable, Spatie-permission-based authorization layer for Laravel: policies, abilities, roles, a permission registry, and a pluggable admin bypass.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Aleksandr Pavliukov"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/auth": "^13.0",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0",
        "illuminate/support": "^13.0",
        "spatie/laravel-permission": "^7.4"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^11.0",
        "phpunit/phpunit": "^11.5 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "AlexPavliukov\\Authorization\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AlexPavliukov\\Authorization\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlexPavliukov\\Authorization\\AuthorizationServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
